# === TrustVault Port Configuration ===
PORT=8000

# === Database (MongoDB Atlas) ===
# DATABASE_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/trustvault?retryWrites=true&w=majority

# === Frontend API URLs ===
NEXT_PUBLIC_API_URL=http://localhost:8000
# Use your machine's LAN IP so the phone can reach the API
EXPO_PUBLIC_API_URL=http://192.168.1.100:8000

# === Expo Monorepo Fix ===
# Required for pnpm monorepos — disables workspace root as Metro server root
EXPO_NO_METRO_WORKSPACE_ROOT=1
