# Database (MongoDB Atlas — get your connection string from Atlas dashboard)
DATABASE_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/trustvault?retryWrites=true&w=majority

# Server
NODE_ENV=development
PORT=3000

# DID Configuration
DEFAULT_DID_METHOD=key

# Credential Defaults
DEFAULT_CREDENTIAL_FORMAT=sd-jwt-vc
DEFAULT_CREDENTIAL_EXPIRY_DAYS=365
STATUS_LIST_SIZE=131072

# Issuer Identity (generated on first run)
ISSUER_DID=
ISSUER_BASE_URL=http://localhost:3000/issuer

# Web Portal (Next.js) — API base URL for browser requests
NEXT_PUBLIC_API_URL=http://localhost:3000

# Mobile Wallet (Expo) — API base URL for device requests
# Use your machine's LAN IP (not localhost) so the phone can reach the API
EXPO_PUBLIC_API_URL=http://192.168.1.100:3000
