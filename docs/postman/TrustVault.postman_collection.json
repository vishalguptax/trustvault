{
  "info": {
    "name": "TrustVault API",
    "description": "Verifiable Credential ecosystem — issuer, wallet, verifier, trust registry",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" }
  ],
  "item": [
    {
      "name": "1. Setup",
      "item": [
        {
          "name": "Health Check (Swagger)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/docs"
          }
        },
        {
          "name": "Get Issuer Metadata",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/issuer/.well-known/openid-credential-issuer"
          }
        },
        {
          "name": "List Credential Schemas",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/issuer/schemas"
          }
        }
      ]
    },
    {
      "name": "2. Trust Registry",
      "item": [
        {
          "name": "Register Trusted Issuer (TrustBank India)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/trust/issuers",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"did\": \"{{issuerDid}}\",\n  \"name\": \"TrustBank India\",\n  \"credentialTypes\": [\"VerifiableIncomeCredential\"],\n  \"description\": \"Licensed bank for income verification\"\n}"
            }
          }
        },
        {
          "name": "Register Trusted Issuer (National Technical University)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/trust/issuers",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"did\": \"{{universityDid}}\",\n  \"name\": \"National Technical University\",\n  \"credentialTypes\": [\"VerifiableEducationCredential\"],\n  \"description\": \"Accredited university\"\n}"
            }
          }
        },
        {
          "name": "List Trusted Issuers",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/trust/issuers"
          }
        },
        {
          "name": "Verify Trust (should pass)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/trust/verify?issuerDid={{issuerDid}}&credentialType=VerifiableIncomeCredential"
          }
        }
      ]
    },
    {
      "name": "3. Issue Credentials",
      "item": [
        {
          "name": "Create Education Credential Offer",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/issuer/offers",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schemaTypeUri\": \"VerifiableEducationCredential\",\n  \"subjectDid\": \"{{holderDid}}\",\n  \"claims\": {\n    \"name\": \"Sandhya Sharma\",\n    \"degree\": \"MSc Computer Science\",\n    \"institution\": \"National Technical University\",\n    \"graduationYear\": 2023,\n    \"gpa\": 3.9\n  }\n}"
            }
          }
        },
        {
          "name": "Create Income Credential Offer",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/issuer/offers",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schemaTypeUri\": \"VerifiableIncomeCredential\",\n  \"subjectDid\": \"{{holderDid}}\",\n  \"claims\": {\n    \"name\": \"Sandhya Sharma\",\n    \"annualIncome\": 95000,\n    \"employer\": \"TechCorp India\",\n    \"currency\": \"INR\"\n  }\n}"
            }
          }
        },
        {
          "name": "Exchange Code for Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/issuer/token",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grant_type\": \"urn:ietf:params:oauth:grant-type:pre-authorized_code\",\n  \"pre-authorized_code\": \"{{preAuthorizedCode}}\"\n}"
            }
          }
        },
        {
          "name": "Request Credential",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/issuer/credential",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"format\": \"vc+sd-jwt\",\n  \"credential_definition\": {\n    \"type\": [\"VerifiableEducationCredential\"]\n  }\n}"
            }
          }
        }
      ]
    },
    {
      "name": "4. Wallet Operations",
      "item": [
        {
          "name": "Receive Credential",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/wallet/credentials/receive",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credentialOfferUri\": \"{{credentialOfferUri}}\",\n  \"holderId\": \"user-1\"\n}"
            }
          }
        },
        {
          "name": "List Wallet Credentials",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/wallet/credentials?holderId=user-1"
          }
        },
        {
          "name": "Create Wallet DID",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/wallet/dids",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"holderId\": \"user-1\",\n  \"method\": \"key\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "5. Verify Credentials",
      "item": [
        {
          "name": "Create Presentation Request",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/verifier/presentations/request",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verifierDid\": \"{{verifierDid}}\",\n  \"credentialTypes\": [\"VerifiableEducationCredential\", \"VerifiableIncomeCredential\"],\n  \"policies\": [\"require-trusted-issuer\", \"require-active-status\", \"require-non-expired\"]\n}"
            }
          }
        },
        {
          "name": "Submit Presentation Response",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/verifier/presentations/response",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vp_token\": \"{{vpToken}}\",\n  \"state\": \"{{state}}\"\n}"
            }
          }
        },
        {
          "name": "Get Verification Result",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/verifier/presentations/{{requestId}}"
          }
        }
      ]
    },
    {
      "name": "6. Revocation",
      "item": [
        {
          "name": "Revoke Credential",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/status/revoke",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credentialId\": \"{{credentialId}}\",\n  \"reason\": \"Credential compromised\"\n}"
            }
          }
        },
        {
          "name": "Get Status List",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/status/lists/{{statusListId}}"
          }
        },
        {
          "name": "Reinstate Credential",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/status/reinstate",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credentialId\": \"{{credentialId}}\"\n}"
            }
          }
        }
      ]
    }
  ]
}
