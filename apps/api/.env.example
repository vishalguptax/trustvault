# === TrustVault API ===
PORT=8000
NODE_ENV=development

# === Database (MongoDB Atlas) ===
DATABASE_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/trustvault?retryWrites=true&w=majority

# === Credential Configuration ===
DEFAULT_DID_METHOD=key
DEFAULT_CREDENTIAL_FORMAT=sd-jwt-vc
DEFAULT_CREDENTIAL_EXPIRY_DAYS=365
STATUS_LIST_SIZE=131072

# === Issuer (generated on first run) ===
ISSUER_DID=
ISSUER_BASE_URL=http://localhost:8000/issuer

# === JWT Authentication ===
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# === CORS ===
CORS_ORIGIN=*
