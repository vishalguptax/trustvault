{
  "name": "@trustvault/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=prisma/schema.prisma",
    "dev": "nest start --watch",
    "build": "prisma generate --schema=prisma/schema.prisma && nest build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "test": "node ../../node_modules/vitest/vitest.mjs run",
    "test:watch": "node ../../node_modules/vitest/vitest.mjs",
    "test:e2e": "node ../../node_modules/vitest/vitest.mjs run --config vitest.e2e.config.ts",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "6.19.2",
    "@sd-jwt/core": "^0.7.0",
    "@sd-jwt/decode": "^0.7.0",
    "@sd-jwt/sd-jwt-vc": "^0.7.0",
    "@sd-jwt/types": "^0.7.0",
    "@sd-jwt/utils": "^0.7.0",
    "@trustvault/shared": "workspace:^",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "compression": "^1.8.1",
    "dotenv": "^17.3.1",
    "helmet": "^8.1.0",
    "jose": "^5.0.0",
    "pako": "^2.1.0",
    "reflect-metadata": "^0.2.0",
    "resend": "^6.10.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@swc/core": "^1.4.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/pako": "^2.0.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "prisma": "6.19.2",
    "rimraf": "^5.0.0",
    "supertest": "^6.0.0",
    "typescript": "^5.8.0",
    "unplugin-swc": "^1.4.0",
    "vitest": "^1.0.0"
  }
}
