{
  "expo": {
    "name": "TrustVault Wallet",
    "slug": "trustvault-wallet",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "trustvault",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0B1120"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.trustvault.wallet"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B1120"
      },
      "package": "com.trustvault.wallet"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "TrustVault needs camera access to scan QR codes."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
