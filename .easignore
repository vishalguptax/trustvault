# Backend — not needed for mobile build
apps/api/
apps/web/

# Native build outputs (regenerated by prebuild)
apps/mobile/android/
apps/mobile/ios/
apps/mobile/.expo/

# Git history (biggest savings)
.git/

# Node modules (EAS runs pnpm install on the server)
node_modules/
apps/*/node_modules/
packages/*/node_modules/

# Build caches
.turbo/
.next/
dist/

# Dev tools and IDE
.claude/
.playwright-mcp/
.idea/
.vscode/
tools/

# Infrastructure
infrastructure/

# Docs
docs/
*.md

# Tests
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
__tests__/

# OS files
.DS_Store
Thumbs.db

# Logs and temp
*.log
*.tmp
*.swp
**/.cache/
